    <!-- Certificate Setup Screen -->
    <string name="cert_setup_title">Approuver le certificat du serveur</string>
    <string name="cert_setup_subtitle">Configuration unique requise</string>
    <string name="cert_setup_intro">ChurchPresenter utilise un certificat HTTPS privé pour une communication sécurisée. Vous devez l\'installer une fois pour que votre appareil approuve la connexion.</string>
    <string name="cert_setup_scan_title">Scanner le QR code du certificat</string>
    <string name="cert_setup_scan_desktop_hint">Sur ChurchPresenter bureau : Paramètres → Serveur → appuyer sur "Télécharger Cert" pour afficher le QR code.</string>
    <string name="cert_setup_scan_button">Scanner le QR Code</string>
    <string name="cert_setup_scan_or_divider">ou utiliser l\'adresse enregistrée</string>
    <string name="cert_setup_url_scanned">✓ URL scannée</string>
    <string name="cert_setup_url_label">URL du certificat</string>
    <string name="cert_setup_open_button">Ouvrir l\'URL du certificat</string>
    <string name="cert_setup_step2_ios_title">iOS — Installer le profil</string>
    <string name="cert_setup_step2_ios_body">Safari demandera de télécharger un profil de configuration. Appuyez sur Autoriser, puis allez dans Réglages → Général → VPN et gestion des appareils, appuyez sur ChurchPresenter et installez.</string>
    <string name="cert_setup_step3_ios_title">iOS — Approuver le certificat</string>
    <string name="cert_setup_step3_ios_body">Réglages → Général → Informations → Réglages de confiance des certificats → activer la confiance totale pour ChurchPresenter CA.</string>
    <string name="cert_setup_step2_android_title">Android — Installer le certificat</string>
    <string name="cert_setup_step2_android_body">Chrome télécharge le fichier .crt. Appuyez dessus depuis la notification Téléchargements, choisissez "Certificat CA" et donnez-lui un nom comme "ChurchPresenter".</string>
    <string name="cert_setup_android_unknown_sources_title">⚠ "Impossible d\'installer depuis des sources inconnues" ?</string>
    <string name="cert_setup_android_unknown_sources_body">Android peut bloquer l\'installation si votre navigateur n\'est pas autorisé. Allez dans Paramètres → Applications → [votre navigateur] → Installer des applications inconnues et activez "Autoriser depuis cette source". Revenez ici et appuyez à nouveau sur le fichier.</string>
    <string name="cert_setup_fingerprint_title">Vérifier l\'empreinte digitale (recommandé)</string>
    <string name="cert_setup_fingerprint_body">Comparez cette empreinte avec ce que ChurchPresenter bureau affiche dans Paramètres → Serveur → SHA-256 du certificat. Elles doivent correspondre.</string>
    <string name="cert_setup_fingerprint_unavailable">Connectez-vous d\'abord au serveur pour voir l\'empreinte</string>
    <string name="cert_setup_done_button">Terminé — Certificat installé</string>
    <string name="cert_setup_skip_button">Ignorer pour l\'instant</string>
    <string name="cert_setup_skip_note">Vous pouvez revenir à ce guide à tout moment depuis Paramètres.</string>

    <!-- Connect Setup Screen -->
    <string name="connect_setup_title">Connecter au bureau</string>
    <string name="connect_setup_subtitle">Configuration unique</string>
    <string name="connect_setup_intro">Scannez le QR code de ChurchPresenter bureau pour configurer automatiquement l\'adresse IP du serveur, le port et la clé API facultative.</string>
    <string name="connect_setup_step1_title">Ouvrir les paramètres dans ChurchPresenter bureau</string>
    <string name="connect_setup_step1_body">Sur votre ordinateur de bureau ou portable, ouvrez l\'application ChurchPresenter et cliquez sur l\'icône Paramètres.</string>
    <string name="connect_setup_step2_title">Aller à l\'onglet Serveur</string>
    <string name="connect_setup_step2_body">Dans Paramètres, sélectionnez l\'onglet Serveur pour trouver vos détails de connexion et le QR code.</string>
    <string name="connect_setup_step3_title">Cliquer sur le bouton QR et scanner</string>
    <string name="connect_setup_step3_body">Cliquez sur le bouton QR pour afficher le QR code de connexion, puis appuyez sur Scanner ci-dessous pour ouvrir la caméra et le scanner.</string>
    <string name="connect_setup_scan_button">Scanner le QR Code</string>
    <string name="connect_setup_connected">✓ Connecté à %1$s:%2$s</string>
    <string name="connect_setup_done_button">Terminé</string>
    <string name="connect_setup_skip_button">Ignorer pour l\'instant</string>
    <string name="connect_setup_skip_note">Vous pouvez scanner le QR code à tout moment depuis Paramètres.</string>
