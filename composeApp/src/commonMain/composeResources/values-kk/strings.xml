    <!-- Certificate Setup Screen -->
    <string name="cert_setup_title">Сервер сертификатына сену</string>
    <string name="cert_setup_subtitle">Бір реттік баптау</string>
    <string name="cert_setup_intro">ChurchPresenter қауіпсіз байланыс үшін жеке HTTPS сертификатын пайдаланады. Құрылғыңыздың қосылымға сенуі үшін оны бір рет орнату қажет.</string>
    <string name="cert_setup_scan_title">Сертификат QR-кодын сканерлеу</string>
    <string name="cert_setup_scan_desktop_hint">ChurchPresenter компьютерде: Параметрлер → Сервер → QR-кодты көрсету үшін "Серт. жүктеу" батырмасын басыңыз.</string>
    <string name="cert_setup_scan_button">QR-кодты сканерлеу</string>
    <string name="cert_setup_scan_or_divider">немесе сақталған мекенжайды пайдалану</string>
    <string name="cert_setup_url_scanned">✓ URL сканерленді</string>
    <string name="cert_setup_url_label">Сертификат URL-і</string>
    <string name="cert_setup_open_button">Сертификат URL-ін ашу</string>
    <string name="cert_setup_step2_ios_title">iOS — Профильді орнату</string>
    <string name="cert_setup_step2_ios_body">Safari конфигурация профилін жүктеуді ұсынады. Рұқсат беруді басыңыз, содан кейін Параметрлер → Жалпы → VPN және құрылғыны басқару бөліміне өтіп, ChurchPresenter-ді басып орнатыңыз.</string>
    <string name="cert_setup_step3_ios_title">iOS — Сертификатқа сену</string>
    <string name="cert_setup_step3_ios_body">Параметрлер → Жалпы → Осы құрылғы туралы → Сертификат сенімділігі параметрлері → ChurchPresenter CA үшін толық сенімділікті қосыңыз.</string>
    <string name="cert_setup_step2_android_title">Android — Сертификатты орнату</string>
    <string name="cert_setup_step2_android_body">Chrome .crt файлын жүктейді. Жүктеулер хабарландыруынан оны басыңыз, "CA сертификаты" таңдап, "ChurchPresenter" деп атаңыз.</string>
    <string name="cert_setup_android_unknown_sources_title">⚠ "Белгісіз көздерден орнату мүмкін емес"?</string>
    <string name="cert_setup_android_unknown_sources_body">Браузеріңізде рұқсат болмаса Android орнатуды бұғаттауы мүмкін. Параметрлер → Қолданбалар → [браузеріңіз] → Белгісіз қолданбаларды орнату бөліміне өтіп, "Осы көзден рұқсат ету" параметрін қосыңыз. Осы жерге оралып файлды қайта басыңыз.</string>
    <string name="cert_setup_fingerprint_title">Саусақ ізін тексеру (ұсынылады)</string>
    <string name="cert_setup_fingerprint_body">Бұл саусақ ізін ChurchPresenter компьютерде Параметрлер → Сервер → Сертификат SHA-256 бөлімінде көрсетілгенмен салыстырыңыз. Олар сәйкес болуы керек.</string>
    <string name="cert_setup_fingerprint_unavailable">Саусақ ізін көру үшін алдымен серверге қосылыңыз</string>
    <string name="cert_setup_done_button">Дайын — Сертификат орнатылды</string>
    <string name="cert_setup_skip_button">Қазір өткізіп жіберу</string>
    <string name="cert_setup_skip_note">Параметрлерден кез келген уақытта осы нұсқаулыққа оралуға болады.</string>

