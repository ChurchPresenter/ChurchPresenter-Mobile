    <!-- Certificate Setup Screen -->
    <string name="cert_setup_title">Důvěřovat certifikátu serveru</string>
    <string name="cert_setup_subtitle">Jednorázové nastavení</string>
    <string name="cert_setup_intro">ChurchPresenter používá soukromý HTTPS certifikát pro bezpečnou komunikaci. Musíte ho jednou nainstalovat, aby vaše zařízení důvěřovalo připojení.</string>
    <string name="cert_setup_scan_title">Naskenujte QR kód certifikátu</string>
    <string name="cert_setup_scan_desktop_hint">V ChurchPresenter na počítači: Nastavení → Server → stiskněte "Stáhnout cert." pro zobrazení QR kódu.</string>
    <string name="cert_setup_scan_button">Skenovat QR kód</string>
    <string name="cert_setup_scan_or_divider">nebo použít uloženou adresu</string>
    <string name="cert_setup_url_scanned">✓ URL naskenováno</string>
    <string name="cert_setup_url_label">URL certifikátu</string>
    <string name="cert_setup_open_button">Otevřít URL certifikátu</string>
    <string name="cert_setup_step2_ios_title">iOS — Nainstalovat profil</string>
    <string name="cert_setup_step2_ios_body">Safari nabídne stažení konfiguračního profilu. Klepněte na Povolit, poté přejděte do Nastavení → Obecné → VPN a správa zařízení, klepněte na ChurchPresenter a nainstalujte.</string>
    <string name="cert_setup_step3_ios_title">iOS — Důvěřovat certifikátu</string>
    <string name="cert_setup_step3_ios_body">Nastavení → Obecné → O zařízení → Nastavení důvěryhodnosti certifikátů → povolit plnou důvěru pro ChurchPresenter CA.</string>
    <string name="cert_setup_step2_android_title">Android — Nainstalovat certifikát</string>
    <string name="cert_setup_step2_android_body">Chrome stáhne soubor .crt. Klepněte na něj v oznámení Stahování, zvolte "Certifikát CA" a pojmenujte ho "ChurchPresenter".</string>
    <string name="cert_setup_android_unknown_sources_title">⚠ "Nelze nainstalovat z neznámých zdrojů"?</string>
    <string name="cert_setup_android_unknown_sources_body">Android může blokovat instalaci, pokud váš prohlížeč nemá oprávnění. Přejděte do Nastavení → Aplikace → [váš prohlížeč] → Instalace neznámých aplikací a povolte "Povolit z tohoto zdroje". Vraťte se sem a znovu klepněte na soubor.</string>
    <string name="cert_setup_fingerprint_title">Ověřit otisk (doporučeno)</string>
    <string name="cert_setup_fingerprint_body">Porovnejte tento otisk s tím, co zobrazuje ChurchPresenter na počítači v Nastavení → Server → SHA-256 certifikátu. Musí se shodovat.</string>
    <string name="cert_setup_fingerprint_unavailable">Nejprve se připojte k serveru, abyste viděli otisk</string>
    <string name="cert_setup_done_button">Hotovo — Certifikát nainstalován</string>
    <string name="cert_setup_skip_button">Přeskočit</string>
    <string name="cert_setup_skip_note">K tomuto průvodci se můžete kdykoli vrátit z Nastavení.</string>

    <!-- Connect Setup Screen -->
    <string name="connect_setup_title">Připojit k počítači</string>
    <string name="connect_setup_subtitle">Jednorázové nastavení</string>
    <string name="connect_setup_intro">Naskenujte QR kód z ChurchPresenter na počítači a automaticky nastavte IP adresu serveru, port a volitelný API klíč.</string>
    <string name="connect_setup_step1_title">Otevřete Nastavení v ChurchPresenter na počítači</string>
    <string name="connect_setup_step1_body">Na počítači otevřete aplikaci ChurchPresenter a klikněte na ikonu Nastavení.</string>
    <string name="connect_setup_step2_title">Přejděte na záložku Server</string>
    <string name="connect_setup_step2_body">V Nastavení vyberte záložku Server, kde najdete údaje o připojení a QR kód.</string>
    <string name="connect_setup_step3_title">Klikněte na tlačítko QR a naskenujte</string>
    <string name="connect_setup_step3_body">Klikněte na tlačítko QR pro zobrazení QR kódu připojení, poté klepněte na Skenovat níže pro otevření kamery a naskenování.</string>
    <string name="connect_setup_scan_button">Skenovat QR kód</string>
    <string name="connect_setup_connected">✓ Připojeno k %1$s:%2$s</string>
