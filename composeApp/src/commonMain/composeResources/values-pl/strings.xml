    <!-- Certificate Setup Screen -->
    <string name="cert_setup_title">Zaufaj certyfikatowi serwera</string>
    <string name="cert_setup_subtitle">Jednorazowa konfiguracja</string>
    <string name="cert_setup_intro">ChurchPresenter używa prywatnego certyfikatu HTTPS do bezpiecznej komunikacji. Musisz go zainstalować raz, aby Twoje urządzenie ufało połączeniu.</string>
    <string name="cert_setup_scan_title">Zeskanuj kod QR certyfikatu</string>
    <string name="cert_setup_scan_desktop_hint">W ChurchPresenter na komputerze: Ustawienia → Serwer → naciśnij "Pobierz cert." aby wyświetlić kod QR.</string>
    <string name="cert_setup_scan_button">Skanuj kod QR</string>
    <string name="cert_setup_scan_or_divider">lub użyj zapisanego adresu</string>
    <string name="cert_setup_url_scanned">✓ URL zeskanowany</string>
    <string name="cert_setup_url_label">URL certyfikatu</string>
    <string name="cert_setup_open_button">Otwórz URL certyfikatu</string>
    <string name="cert_setup_step2_ios_title">iOS — Zainstaluj profil</string>
    <string name="cert_setup_step2_ios_body">Safari poprosi o pobranie profilu konfiguracyjnego. Stuknij Zezwól, następnie przejdź do Ustawienia → Ogólne → VPN i zarządzanie urządzeniem, stuknij ChurchPresenter i zainstaluj.</string>
    <string name="cert_setup_step3_ios_title">iOS — Zaufaj certyfikatowi</string>
    <string name="cert_setup_step3_ios_body">Ustawienia → Ogólne → Informacje → Ustawienia zaufania certyfikatów → włącz pełne zaufanie dla ChurchPresenter CA.</string>
    <string name="cert_setup_step2_android_title">Android — Zainstaluj certyfikat</string>
    <string name="cert_setup_step2_android_body">Chrome pobierze plik .crt. Stuknij go w powiadomieniu Pobierania, wybierz "Certyfikat CA" i nadaj mu nazwę "ChurchPresenter".</string>
    <string name="cert_setup_android_unknown_sources_title">⚠ "Nie można zainstalować z nieznanych źródeł"?</string>
    <string name="cert_setup_android_unknown_sources_body">Android może blokować instalację, jeśli Twoja przeglądarka nie ma uprawnień. Przejdź do Ustawienia → Aplikacje → [Twoja przeglądarka] → Instaluj nieznane aplikacje i włącz "Zezwól z tego źródła". Wróć tutaj i ponownie stuknij plik.</string>
    <string name="cert_setup_fingerprint_title">Weryfikacja odcisku (zalecane)</string>
    <string name="cert_setup_fingerprint_body">Porównaj ten odcisk z tym, co ChurchPresenter na komputerze pokazuje w Ustawienia → Serwer → SHA-256 certyfikatu. Muszą być identyczne.</string>
    <string name="cert_setup_fingerprint_unavailable">Najpierw połącz się z serwerem, aby zobaczyć odcisk</string>
    <string name="cert_setup_done_button">Gotowe — Certyfikat zainstalowany</string>
    <string name="cert_setup_skip_button">Pomiń na razie</string>
    <string name="cert_setup_skip_note">Możesz wrócić do tego przewodnika w dowolnym momencie z Ustawień.</string>

    <!-- Connect Setup Screen -->
    <string name="connect_setup_title">Połącz z komputerem</string>
    <string name="connect_setup_subtitle">Jednorazowa konfiguracja</string>
    <string name="connect_setup_intro">Zeskanuj kod QR z ChurchPresenter na komputerze, aby automatycznie ustawić adres IP serwera, port i opcjonalny klucz API.</string>
    <string name="connect_setup_step1_title">Otwórz Ustawienia w ChurchPresenter na komputerze</string>
    <string name="connect_setup_step1_body">Na komputerze otwórz aplikację ChurchPresenter i kliknij ikonę Ustawień.</string>
    <string name="connect_setup_step2_title">Przejdź do zakładki Serwer</string>
    <string name="connect_setup_step2_body">W Ustawieniach wybierz zakładkę Serwer, aby znaleźć dane połączenia i kod QR.</string>
    <string name="connect_setup_step3_title">Kliknij przycisk QR i zeskanuj</string>
    <string name="connect_setup_step3_body">Kliknij przycisk QR, aby wyświetlić kod QR połączenia, następnie stuknij Skanuj poniżej, aby otworzyć kamerę i zeskanować.</string>
    <string name="connect_setup_scan_button">Skanuj kod QR</string>
    <string name="connect_setup_connected">✓ Połączono z %1$s:%2$s</string>
    <string name="connect_setup_done_button">Gotowe</string>
    <string name="connect_setup_skip_button">Pomiń na razie</string>
    <string name="connect_setup_skip_note">Kod QR możesz zeskanować w dowolnym momencie z Ustawień.</string>
