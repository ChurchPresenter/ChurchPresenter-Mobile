    <!-- Certificate Setup Screen -->
    <string name="cert_setup_title">Confiar en el certificado del servidor</string>
    <string name="cert_setup_subtitle">Configuración única requerida</string>
    <string name="cert_setup_intro">ChurchPresenter usa un certificado HTTPS privado para comunicación segura. Debe instalarlo una vez para que su dispositivo confíe en la conexión.</string>
    <string name="cert_setup_scan_title">Escanee el código QR del certificado</string>
    <string name="cert_setup_scan_desktop_hint">En ChurchPresenter escritorio: Ajustes → Servidor → presione "Descargar Cert" para mostrar el código QR.</string>
    <string name="cert_setup_scan_button">Escanear código QR</string>
    <string name="cert_setup_scan_or_divider">o use la dirección guardada</string>
    <string name="cert_setup_url_scanned">✓ URL escaneada</string>
    <string name="cert_setup_url_label">URL del certificado</string>
    <string name="cert_setup_open_button">Abrir URL del certificado</string>
    <string name="cert_setup_step2_ios_title">iOS — Instalar el perfil</string>
    <string name="cert_setup_step2_ios_body">Safari pedirá descargar un perfil de configuración. Toque Permitir, luego vaya a Ajustes → General → VPN y gestión de dispositivos, toque ChurchPresenter e instale.</string>
    <string name="cert_setup_step3_ios_title">iOS — Confiar en el certificado</string>
    <string name="cert_setup_step3_ios_body">Ajustes → General → Información → Ajustes de confianza de certificados → activar plena confianza para ChurchPresenter CA.</string>
    <string name="cert_setup_step2_android_title">Android — Instalar el certificado</string>
    <string name="cert_setup_step2_android_body">Chrome descarga el archivo .crt. Tóquelo desde la notificación de Descargas, elija "Certificado CA" y asígnele un nombre como "ChurchPresenter".</string>
    <string name="cert_setup_android_unknown_sources_title">⚠ "¿No se puede instalar de fuentes desconocidas"?</string>
    <string name="cert_setup_android_unknown_sources_body">Android puede bloquear la instalación si su navegador no tiene permiso. Vaya a Ajustes → Aplicaciones → [su navegador] → Instalar apps desconocidas y active "Permitir desde esta fuente". Regrese aquí y toque el archivo de nuevo.</string>
    <string name="cert_setup_fingerprint_title">Verificar huella digital (recomendado)</string>
    <string name="cert_setup_fingerprint_body">Compare esta huella digital con la que muestra ChurchPresenter escritorio en Ajustes → Servidor → SHA-256 del certificado. Deben coincidir.</string>
    <string name="cert_setup_fingerprint_unavailable">Conéctese al servidor primero para ver la huella digital</string>
    <string name="cert_setup_done_button">Listo — Certificado instalado</string>
    <string name="cert_setup_skip_button">Omitir por ahora</string>
    <string name="cert_setup_skip_note">Puede volver a esta guía en cualquier momento desde Ajustes.</string>

    <!-- Connect Setup Screen -->
    <string name="connect_setup_title">Conectar al escritorio</string>
    <string name="connect_setup_subtitle">Configuración única</string>
    <string name="connect_setup_intro">Escanee el código QR de ChurchPresenter escritorio para configurar la dirección IP del servidor, puerto y clave API opcional automáticamente.</string>
    <string name="connect_setup_step1_title">Abrir Ajustes en ChurchPresenter escritorio</string>
    <string name="connect_setup_step1_body">En su computadora de escritorio o portátil, abra la aplicación ChurchPresenter y haga clic en el icono de Ajustes.</string>
    <string name="connect_setup_step2_title">Ir a la pestaña Servidor</string>
    <string name="connect_setup_step2_body">Dentro de Ajustes, seleccione la pestaña Servidor para encontrar los detalles de conexión y el código QR.</string>
    <string name="connect_setup_step3_title">Haga clic en el botón QR y escanee</string>
    <string name="connect_setup_step3_body">Haga clic en el botón QR para mostrar el código QR de conexión, luego toque Escanear abajo para abrir la cámara y escanearlo.</string>
    <string name="connect_setup_scan_button">Escanear código QR</string>
    <string name="connect_setup_connected">✓ Conectado a %1$s:%2$s</string>
    <string name="connect_setup_done_button">Listo</string>
    <string name="connect_setup_skip_button">Omitir por ahora</string>
    <string name="connect_setup_skip_note">Puede escanear el código QR en cualquier momento desde Ajustes.</string>
