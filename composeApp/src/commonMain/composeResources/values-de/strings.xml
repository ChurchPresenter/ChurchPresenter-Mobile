    <!-- Certificate Setup Screen -->
    <string name="cert_setup_title">Server-Zertifikat vertrauen</string>
    <string name="cert_setup_subtitle">Einmalige Einrichtung erforderlich</string>
    <string name="cert_setup_intro">ChurchPresenter verwendet ein privates HTTPS-Zertifikat für sichere Kommunikation. Sie müssen es einmal installieren, damit Ihr Gerät der Verbindung vertraut.</string>
    <string name="cert_setup_scan_title">QR-Code des Zertifikats scannen</string>
    <string name="cert_setup_scan_desktop_hint">In ChurchPresenter Desktop: Einstellungen → Server → "Zert. herunterladen" drücken, um den QR-Code anzuzeigen.</string>
    <string name="cert_setup_scan_button">QR-Code scannen</string>
    <string name="cert_setup_scan_or_divider">oder gespeicherte Adresse verwenden</string>
    <string name="cert_setup_url_scanned">✓ URL gescannt</string>
    <string name="cert_setup_url_label">Zertifikat-URL</string>
    <string name="cert_setup_open_button">Zertifikat-URL öffnen</string>
    <string name="cert_setup_step2_ios_title">iOS — Profil installieren</string>
    <string name="cert_setup_step2_ios_body">Safari wird nach dem Herunterladen eines Konfigurationsprofils fragen. Tippen Sie auf Erlauben, gehen Sie dann zu Einstellungen → Allgemein → VPN &amp; Geräteverwaltung, tippen Sie auf ChurchPresenter und installieren Sie es.</string>
    <string name="cert_setup_step3_ios_title">iOS — Zertifikat vertrauen</string>
    <string name="cert_setup_step3_ios_body">Einstellungen → Allgemein → Info → Zertifikat-Vertrauenseinstellungen → volle Vertrauenswürdigkeit für ChurchPresenter CA aktivieren.</string>
    <string name="cert_setup_step2_android_title">Android — Zertifikat installieren</string>
    <string name="cert_setup_step2_android_body">Chrome lädt die .crt-Datei herunter. Tippen Sie darauf in der Download-Benachrichtigung, wählen Sie "CA-Zertifikat" und geben Sie ihm einen Namen wie "ChurchPresenter".</string>
    <string name="cert_setup_android_unknown_sources_title">⚠ "Kann nicht aus unbekannten Quellen installieren"?</string>
    <string name="cert_setup_android_unknown_sources_body">Android kann die Installation blockieren, wenn Ihr Browser nicht berechtigt ist. Gehen Sie zu Einstellungen → Apps → [Ihr Browser] → Unbekannte Apps installieren und aktivieren Sie "Aus dieser Quelle zulassen". Kehren Sie hierher zurück und tippen Sie erneut auf die Datei.</string>
    <string name="cert_setup_fingerprint_title">Fingerabdruck prüfen (empfohlen)</string>
    <string name="cert_setup_fingerprint_body">Vergleichen Sie diesen Fingerabdruck mit dem, was ChurchPresenter Desktop in Einstellungen → Server → Zertifikat SHA-256 anzeigt. Sie müssen übereinstimmen.</string>
    <string name="cert_setup_fingerprint_unavailable">Zuerst mit dem Server verbinden, um den Fingerabdruck zu sehen</string>
    <string name="cert_setup_done_button">Fertig — Zertifikat installiert</string>
    <string name="cert_setup_skip_button">Vorerst überspringen</string>
    <string name="cert_setup_skip_note">Sie können jederzeit über Einstellungen zu diesem Leitfaden zurückkehren.</string>

    <!-- Connect Setup Screen -->
    <string name="connect_setup_title">Mit Desktop verbinden</string>
    <string name="connect_setup_subtitle">Einmalige Einrichtung</string>
    <string name="connect_setup_intro">Scannen Sie den QR-Code von ChurchPresenter Desktop, um IP-Adresse, Port und optionalen API-Schlüssel automatisch einzustellen.</string>
    <string name="connect_setup_step1_title">Einstellungen in ChurchPresenter Desktop öffnen</string>
    <string name="connect_setup_step1_body">Öffnen Sie auf Ihrem Desktop oder Laptop die ChurchPresenter-App und klicken Sie auf das Einstellungssymbol.</string>
    <string name="connect_setup_step2_title">Zum Reiter Server wechseln</string>
    <string name="connect_setup_step2_body">Wählen Sie in den Einstellungen den Reiter Server, um Ihre Verbindungsdetails und den QR-Code zu finden.</string>
    <string name="connect_setup_step3_title">QR-Code-Schaltfläche klicken und scannen</string>
    <string name="connect_setup_step3_body">Klicken Sie auf die QR-Schaltfläche, um den Verbindungs-QR-Code anzuzeigen, und tippen Sie dann unten auf Scannen, um die Kamera zu öffnen.</string>
    <string name="connect_setup_scan_button">QR-Code scannen</string>
    <string name="connect_setup_connected">✓ Verbunden mit %1$s:%2$s</string>
    <string name="connect_setup_done_button">Fertig</string>
    <string name="connect_setup_skip_button">Vorerst überspringen</string>
    <string name="connect_setup_skip_note">Sie können den QR-Code jederzeit über Einstellungen scannen.</string>
