    <!-- Certificate Setup Screen -->
    <string name="cert_setup_title">Доверять сертификату сервера</string>
    <string name="cert_setup_subtitle">Одноразовая настройка</string>
    <string name="cert_setup_intro">ChurchPresenter использует частный HTTPS-сертификат для безопасной связи. Нужно установить его один раз, чтобы ваше устройство доверяло соединению.</string>
    <string name="cert_setup_scan_title">Отсканируйте QR-код сертификата</string>
    <string name="cert_setup_scan_desktop_hint">В ChurchPresenter на компьютере: Настройки → Сервер → нажмите "Загрузить серт." для отображения QR-кода.</string>
    <string name="cert_setup_scan_button">Сканировать QR-код</string>
    <string name="cert_setup_scan_or_divider">или использовать сохранённый адрес</string>
    <string name="cert_setup_url_scanned">✓ URL отсканирован</string>
    <string name="cert_setup_url_label">URL сертификата</string>
    <string name="cert_setup_open_button">Открыть URL сертификата</string>
    <string name="cert_setup_step2_ios_title">iOS — Установить профиль</string>
    <string name="cert_setup_step2_ios_body">Safari предложит загрузить профиль конфигурации. Нажмите Разрешить, затем перейдите в Настройки → Основные → VPN и управление устройством, нажмите ChurchPresenter и установите.</string>
    <string name="cert_setup_step3_ios_title">iOS — Доверять сертификату</string>
    <string name="cert_setup_step3_ios_body">Настройки → Основные → Об этом устройстве → Настройки доверия сертификатов → включить полное доверие для ChurchPresenter CA.</string>
    <string name="cert_setup_step2_android_title">Android — Установить сертификат</string>
    <string name="cert_setup_step2_android_body">Chrome скачает файл .crt. Нажмите на него в уведомлении Загрузки, выберите "Сертификат ЦС" и дайте ему название "ChurchPresenter".</string>
    <string name="cert_setup_android_unknown_sources_title">⚠ "Невозможно установить из неизвестных источников"?</string>
    <string name="cert_setup_android_unknown_sources_body">Android может заблокировать установку, если ваш браузер не имеет разрешения. Перейдите в Настройки → Приложения → [ваш браузер] → Установка неизвестных приложений и включите "Разрешить из этого источника". Вернитесь сюда и снова нажмите на файл.</string>
    <string name="cert_setup_fingerprint_title">Проверить отпечаток (рекомендуется)</string>
    <string name="cert_setup_fingerprint_body">Сравните этот отпечаток с тем, что отображает ChurchPresenter на компьютере в Настройки → Сервер → SHA-256 сертификата. Они должны совпадать.</string>
    <string name="cert_setup_fingerprint_unavailable">Сначала подключитесь к серверу, чтобы увидеть отпечаток</string>
    <string name="cert_setup_done_button">Готово — Сертификат установлен</string>
    <string name="cert_setup_skip_button">Пропустить сейчас</string>
    <string name="cert_setup_skip_note">Вы можете вернуться к этому руководству в любое время из Настроек.</string>

    <!-- Connect Setup Screen -->
    <string name="connect_setup_title">Подключиться к компьютеру</string>
    <string name="connect_setup_subtitle">Одноразовая настройка</string>
    <string name="connect_setup_intro">Отсканируйте QR-код из ChurchPresenter на компьютере, чтобы автоматически настроить IP-адрес сервера, порт и необязательный API-ключ.</string>
    <string name="connect_setup_step1_title">Откройте Настройки в ChurchPresenter на компьютере</string>
    <string name="connect_setup_step1_body">На вашем компьютере откройте приложение ChurchPresenter и нажмите значок Настройки.</string>
    <string name="connect_setup_step2_title">Перейдите на вкладку Сервер</string>
    <string name="connect_setup_step2_body">В Настройках выберите вкладку Сервер, чтобы найти данные подключения и QR-код.</string>
    <string name="connect_setup_step3_title">Нажмите кнопку QR и отсканируйте</string>
    <string name="connect_setup_step3_body">Нажмите кнопку QR для отображения QR-кода подключения, затем нажмите Сканировать ниже, чтобы открыть камеру и отсканировать его.</string>
    <string name="connect_setup_scan_button">Сканировать QR-код</string>
    <string name="connect_setup_connected">✓ Подключено к %1$s:%2$s</string>
    <string name="connect_setup_done_button">Готово</string>
    <string name="connect_setup_skip_button">Пропустить сейчас</string>
    <string name="connect_setup_skip_note">Вы можете отсканировать QR-код в любое время из Настроек.</string>
